# App
PORT=8787
APP_URL=http://localhost:8787

# Video generation
# Use "mock" for local testing without API spend.
# Use "dashscope" after adding an Alibaba Cloud Model Studio / Bailian API key.
# Use "openai" after your OpenAI account has video generation API access.
VIDEO_PROVIDER=mock
DASHSCOPE_API_KEY=
DASHSCOPE_VIDEO_MODEL=wan2.6-i2v-flash
DASHSCOPE_AUDIO=false
# Keep false by default to reduce identity drift and face/object distortion.
DASHSCOPE_PROMPT_EXTEND=false
# Internal ops estimate for the private dashboard. This does not affect provider billing.
ESTIMATED_VIDEO_COST_CNY=0.6
# Conservative cost guardrails for real providers only. Mock jobs are not counted.
# Set lower values during launch if you want to cap Alibaba Cloud spend tightly.
MAX_DAILY_VIDEO_JOBS=10
MAX_DAILY_VIDEO_JOBS_PER_USER=2
# Upload guardrail for JPG, PNG, and WebP input images.
MAX_UPLOAD_IMAGE_MB=8
# New anonymous accounts receive this many starter credits.
# 2 credits allow one standard 4s / 720p test generation before purchase.
STARTER_CREDITS=2
OPENAI_API_KEY=
OPENAI_VIDEO_MODEL=sora-2

# Data storage
# Use "file" locally. Use "supabase" on Render so credits survive redeploys.
DATA_PROVIDER=file
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
# Keep false until the reviewed RPC SQL is installed and verified in Supabase.
SUPABASE_ATOMIC_CREDIT_RPC=false
# Optional for real email login via Supabase Auth magic links.
# This must be a public/publishable/anon auth key, not the service-role secret.
SUPABASE_AUTH_ANON_KEY=
AUTH_COOKIE_SECRET=

# Analytics admin
# Optional. Set this on Render to protect /api/admin/analytics.
ANALYTICS_ADMIN_TOKEN=

# Object storage
# Keep "none" until Cloudflare R2 is ready.
# Use "r2" to save uploaded images and generated videos.
STORAGE_PROVIDER=none
CLOUDFLARE_R2_ACCOUNT_ID=
CLOUDFLARE_R2_ACCESS_KEY_ID=
CLOUDFLARE_R2_SECRET_ACCESS_KEY=
CLOUDFLARE_R2_BUCKET=
CLOUDFLARE_R2_PUBLIC_BASE_URL=

# Payments
# Use "mock" while testing locally. Use "creem" after creating products in Creem.
PAYMENT_PROVIDER=mock

# Creem
# Test mode uses https://test-api.creem.io. Production uses https://api.creem.io.
CREEM_TEST_MODE=true
CREEM_API_KEY=
CREEM_WEBHOOK_SECRET=
CREEM_PRODUCT_CREATOR=
CREEM_PRODUCT_COMMERCE=

# Credit packs. Keep these values aligned with Creem product descriptions.
# Controlled-live values selected for the first launch.
CREATOR_PACK_CREDITS=40
COMMERCE_PACK_CREDITS=160
CREATOR_PACK_PRICE_LABEL=$9
COMMERCE_PACK_PRICE_LABEL=$29

# Stripe fallback, only needed if you switch PAYMENT_PROVIDER=stripe later.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_CREATOR=
STRIPE_PRICE_COMMERCE=
