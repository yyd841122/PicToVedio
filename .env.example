# App
PORT=8787
APP_URL=http://localhost:8787

# Video generation
# Use "mock" for local testing without API spend.
# Use "dashscope" after adding an Alibaba Cloud Model Studio / Bailian API key.
# Use "openai" after your OpenAI account has video generation API access.
VIDEO_PROVIDER=mock
DASHSCOPE_API_KEY=
DASHSCOPE_VIDEO_MODEL=wan2.6-i2v-flash
DASHSCOPE_AUDIO=false
# Internal ops estimate for the private dashboard. This does not affect provider billing.
ESTIMATED_VIDEO_COST_CNY=0.6
OPENAI_API_KEY=
OPENAI_VIDEO_MODEL=sora-2

# Data storage
# Use "file" locally. Use "supabase" on Render so credits survive redeploys.
DATA_PROVIDER=file
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Analytics admin
# Optional. Set this on Render to protect /api/admin/analytics.
ANALYTICS_ADMIN_TOKEN=

# Object storage
# Keep "none" until Cloudflare R2 is ready.
# Use "r2" to save uploaded images and generated videos.
STORAGE_PROVIDER=none
CLOUDFLARE_R2_ACCOUNT_ID=
CLOUDFLARE_R2_ACCESS_KEY_ID=
CLOUDFLARE_R2_SECRET_ACCESS_KEY=
CLOUDFLARE_R2_BUCKET=
CLOUDFLARE_R2_PUBLIC_BASE_URL=

# Payments
# Use "mock" while testing locally. Use "creem" after creating products in Creem.
PAYMENT_PROVIDER=mock

# Creem
# Test mode uses https://test-api.creem.io. Production uses https://api.creem.io.
CREEM_TEST_MODE=true
CREEM_API_KEY=
CREEM_WEBHOOK_SECRET=
CREEM_PRODUCT_CREATOR=
CREEM_PRODUCT_COMMERCE=

# Stripe fallback, only needed if you switch PAYMENT_PROVIDER=stripe later.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_CREATOR=
STRIPE_PRICE_COMMERCE=
